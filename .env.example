NODE_ENV=development
PORT=3000
PATCHPACT_BASE_URL=http://localhost:3000
PATCHPACT_GITHUB_APP_NAME=PatchPact
PATCHPACT_GITHUB_APP_DESCRIPTION=Contract-first GitHub App for open source maintainers.
PATCHPACT_GITHUB_APP_PUBLIC=false
PATCHPACT_GITHUB_APP_REGISTRATION_OWNER=
PATCHPACT_INLINE_JOBS=true
PATCHPACT_STORAGE=memory
PATCHPACT_GITHUB_APP_ID=
PATCHPACT_GITHUB_WEBHOOK_SECRET=development-secret
PATCHPACT_GITHUB_PRIVATE_KEY=
PATCHPACT_GITHUB_CLIENT_ID=
PATCHPACT_GITHUB_CLIENT_SECRET=
PATCHPACT_DEFAULT_PROVIDER=mock
PATCHPACT_OPENAI_BASE_URL=https://api.openai.com/v1
PATCHPACT_OPENAI_API_KEY=
PATCHPACT_OPENAI_MODEL=gpt-4.1-mini
PATCHPACT_ANTHROPIC_API_KEY=
PATCHPACT_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PATCHPACT_OLLAMA_BASE_URL=http://localhost:11434
PATCHPACT_OLLAMA_MODEL=qwen2.5-coder:7b
DATABASE_URL=postgres://postgres:postgres@localhost:5432/patchpact
REDIS_URL=redis://localhost:6379
